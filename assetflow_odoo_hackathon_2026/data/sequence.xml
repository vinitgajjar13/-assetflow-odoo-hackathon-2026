        <field name="number_increment">1</field>
    </record>

    <!-- Transfer -->
    <record id="seq_transfer" model="ir.sequence">
        <field name="name">Transfer</field>
        <field name="code">assetflow.transfer</field>
        <field name="prefix">TR-</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
    </record>

    <!-- Audit -->
    <record id="seq_audit" model="ir.sequence">
