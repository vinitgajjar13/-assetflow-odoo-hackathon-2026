<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Department -->
    <record id="seq_department" model="ir.sequence">
        <field name="name">Department</field>
        <field name="code">assetflow.department</field>
        <field name="prefix">DEPT-</field>
        <field name="padding">3</field>
        <field name="number_increment">1</field>
    </record>

    <!-- Asset -->
    <record id="seq_asset" model="ir.sequence">
        <field name="name">Asset</field>
        <field name="code">assetflow.asset</field>
        <field name="prefix">AF-</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
    </record>

    <!-- Employee -->
    <record id="seq_employee" model="ir.sequence">
        <field name="name">Employee</field>
        <field name="code">assetflow.employee</field>
        <field name="prefix">EMP-</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
    </record>

    <!-- Allocation -->
    <record id="seq_allocation" model="ir.sequence">
        <field name="name">Allocation</field>
        <field name="code">assetflow.allocation</field>
        <field name="prefix">AL-</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
    </record>

