<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_asset_allocation_list" model="ir.ui.view">
        <field name="name">assetflow.asset.allocation.list</field>
        <field name="model">assetflow.asset.allocation</field>
        <field name="arch" type="xml">
            <list string="Asset Allocations">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="employee_id"/>
                <field name="allocation_date"/>
                <field name="expected_return_date"/>
                <field name="actual_return_date" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'allocated'"
                       decoration-muted="state == 'returned'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_asset_allocation_form" model="ir.ui.view">
        <field name="name">assetflow.asset.allocation.form</field>
        <field name="model">assetflow.asset.allocation</field>
        <field name="arch" type="xml">
            <form string="Asset Allocation">
                <header>
                    <button name="action_allocate" type="object" string="Confirm Allocation" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_return" type="object" string="Return Asset" class="oe_highlight" invisible="state != 'allocated'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,allocated,returned"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Asset &amp; Employee">
                            <field name="asset_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="employee_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                        </group>
                        <group string="Dates">
                            <field name="allocation_date" readonly="state != 'draft'"/>
                            <field name="expected_return_date" readonly="state != 'draft'"/>
                            <field name="actual_return_date"/>
                            
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" placeholder="Additional details..." readonly="state == 'returned'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_asset_allocation_search" model="ir.ui.view">
        <field name="name">assetflow.asset.allocation.search</field>
        <field name="model">assetflow.asset.allocation</field>
        <field name="arch" type="xml">
            <search string="Search Allocations">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="employee_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Allocated" name="allocated" domain="[('state', '=', 'allocated')]"/>
                <filter string="Returned" name="returned" domain="[('state', '=', 'returned')]"/>
                <group expand="0" string="Group By">
                    <filter string="Asset" name="group_by_asset" context="{'group_by': 'asset_id'}"/>
                    <filter string="Employee" name="group_by_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Status" name="group_by_status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_asset_allocation" model="ir.actions.act_window">
        <field name="name">Asset Allocations</field>
        <field name="res_model">assetflow.asset.allocation</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_asset_allocation_search"/>
    </record>

    <!-- Menu -->
    <menuitem id="menu_assetflow_allocation"
              name="Allocations"
              parent="menu_assetflow_root"
              action="action_asset_allocation"
              sequence="30"/>

</odoo>