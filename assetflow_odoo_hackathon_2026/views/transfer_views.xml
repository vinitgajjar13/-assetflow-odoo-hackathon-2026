<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_transfer_list" model="ir.ui.view">
        <field name="name">assetflow.transfer.list</field>
        <field name="model">assetflow.transfer</field>
        <field name="arch" type="xml">
            <list string="Asset Transfers">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="from_employee_id"/>
                <field name="to_employee_id"/>
                <field name="request_date"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'requested'"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_transfer_form" model="ir.ui.view">
        <field name="name">assetflow.transfer.form</field>
        <field name="model">assetflow.transfer</field>
        <field name="arch" type="xml">
            <form string="Asset Transfer">
                <header>
                    <button name="action_submit" type="object" string="Submit Request" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve" class="oe_highlight" groups="assetflow_odoo_hackathon_2026.group_assetflow_manager" invisible="state != 'requested'"/>
                    <button name="action_reject" type="object" string="Reject" groups="assetflow_odoo_hackathon_2026.group_assetflow_manager" invisible="state != 'requested'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,requested,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Asset Details">
                            <field name="asset_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="from_employee_id" force_save="1"/>
                        </group>
                        <group string="Transfer Target">
                            <field name="to_employee_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="request_date" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <group string="Transfer Reason">
                        <field name="reason" placeholder="Explain why this transfer is needed..." readonly="state in ('approved', 'rejected')"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_transfer_search" model="ir.ui.view">
        <field name="name">assetflow.transfer.search</field>
        <field name="model">assetflow.transfer</field>
        <field name="arch" type="xml">
            <search string="Search Transfers">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="from_employee_id"/>
                <field name="to_employee_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Requested" name="requested" domain="[('state', '=', 'requested')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter string="Asset" name="group_by_asset" context="{'group_by': 'asset_id'}"/>
                    <filter string="From Employee" name="group_by_from" context="{'group_by': 'from_employee_id'}"/>
                    <filter string="To Employee" name="group_by_to" context="{'group_by': 'to_employee_id'}"/>
                    <filter string="Status" name="group_by_status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_transfer" model="ir.actions.act_window">
        <field name="name">Transfer Requests</field>
        <field name="res_model">assetflow.transfer</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_transfer_search"/>
    </record>

    <!-- Menu -->
    <menuitem id="menu_assetflow_transfer"
              name="Transfers"
              parent="menu_assetflow_root"
              action="action_transfer"
              sequence="40"/>

</odoo>