<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- LIST -->
    <record id="view_transfer_tree" model="ir.ui.view">
        <field name="name">assetflow.transfer.tree</field>
        <field name="model">assetflow.transfer</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="asset_id"/>
                <field name="from_employee_id"/>
                <field name="to_employee_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_transfer_form" model="ir.ui.view">
        <field name="name">assetflow.transfer.form</field>
        <field name="model">assetflow.transfer</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <group>
                        <field name="name" readonly="1"/>
                        <field name="asset_id"/>
                    </group>

                    <group>
                        <field name="from_employee_id"/>
                        <field name="to_employee_id"/>
                    </group>

                    <group>
                        <field name="request_date"/>
                        <field name="state"/>
                    </group>

                    <group>
                        <field name="reason"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_transfer" model="ir.actions.act_window">
        <field name="name">Transfer Requests</field>
        <field name="res_model">assetflow.transfer</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENU -->
    <menuitem
        id="menu_assetflow_transfer"
        name="Transfers"
        parent="menu_assetflow_root"
        action="action_transfer"
        sequence="40"/>

</odoo>