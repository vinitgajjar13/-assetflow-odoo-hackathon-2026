<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_asset_history_list" model="ir.ui.view">
        <field name="name">assetflow.asset.history.list</field>
        <field name="model">assetflow.asset.history</field>
        <field name="arch" type="xml">
            <list string="Asset History" create="false" edit="false" delete="false">
                <field name="date"/>
                <field name="asset_id"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="action" widget="badge"/>
                <field name="previous_status" optional="show"/>
                <field name="current_status" widget="badge"
                       decoration-success="current_status == 'available'"
                       decoration-info="current_status == 'allocated'"
                       decoration-warning="current_status == 'maintenance'"
                       decoration-danger="current_status == 'lost'"
                       decoration-muted="current_status in ('retired', 'disposed')"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_asset_history_form" model="ir.ui.view">
        <field name="name">assetflow.asset.history.form</field>
        <field name="model">assetflow.asset.history</field>
        <field name="arch" type="xml">
            <form string="Asset History" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group string="Asset &amp; Assignment">
                            <field name="asset_id" readonly="1"/>
                            <field name="employee_id" readonly="1"/>
                            <field name="department_id" readonly="1"/>
                            <field name="action" readonly="1"/>
                        </group>
                        <group string="Status &amp; Actor">
                            <field name="previous_status" readonly="1"/>
                            <field name="current_status" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                            <field name="date" readonly="1"/>
                        </group>
                    </group>
                    <group string="Remarks">
                        <field name="remarks" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
<record id="view_asset_history_search" model="ir.ui.view">
    <field name="name">assetflow.asset.history.search</field>
    <field name="model">assetflow.asset.history</field>
    <field name="arch" type="xml">
        <search string="Asset History">
            <field name="asset_id"/>
            <field name="employee_id"/>
            <field name="action"/>
            <field name="date"/>

            <filter name="registered"
                    string="Registered"
                    domain="[('action','=','registered')]"/>

            <filter name="allocated"
                    string="Allocated"
                    domain="[('action','=','allocated')]"/>

            <filter name="returned"
                    string="Returned"
                    domain="[('action','=','returned')]"/>
        </search>
    </field>
</record>

    <!-- Action -->
    <record id="action_asset_history" model="ir.actions.act_window">
        <field name="name">Asset History</field>
        <field name="res_model">assetflow.asset.history</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_asset_history_search"/>
    </record>

    <!-- Menu -->
    <menuitem id="menu_asset_history"
              name="Asset History"
              parent="menu_assetflow_root"
              action="action_asset_history"
              sequence="90"/>

</odoo>