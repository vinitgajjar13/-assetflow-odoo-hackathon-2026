<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- LIST -->
    <record id="view_employee_tree_assetflow" model="ir.ui.view">
        <field name="name">assetflow.employee.tree</field>
        <field name="model">hr.employee</field>
        <field name="arch" type="xml">
            <list string="Employees">
                <field name="name"/>
                <field name="department_id"/>
                <field name="job_title"/>
                <field name="work_email"/>
                <field name="allocated_asset_count"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_employee_form_assetflow" model="ir.ui.view">
        <field name="name">assetflow.employee.form</field>
        <field name="model">hr.employee</field>
        <field name="arch" type="xml">
            <form string="Employee">
                <sheet>

                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_view_allocated_assets"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-laptop">
                            <field name="allocated_asset_count"
                                   widget="statinfo"
                                   string="Assets"/>
                        </button>
                    </div>

                    <group>
                        <group>
                            <field name="name"/>
                            <field name="department_id"/>
                            <field name="job_title"/>
                        </group>

                        <group>
                            <field name="work_email"/>
                            <field name="work_phone"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Allocated Assets">

                            <field name="allocated_asset_ids" readonly="1">

                                <list>

                                    <field name="asset_id"/>

                                    <field name="allocation_date"/>

                                    <field name="expected_return_date"/>

                                    <field name="state"/>

                                </list>

                            </field>

                        </page>

                    </notebook>

                </sheet>

            </form>

        </field>

    </record>

    <!-- SEARCH -->

    <record id="view_employee_search_assetflow" model="ir.ui.view">

        <field name="name">assetflow.employee.search</field>

        <field name="model">hr.employee</field>

        <field name="arch" type="xml">

            <search>

                <field name="name"/>

                <field name="department_id"/>

                <field name="work_email"/>

            </search>

        </field>

    </record>

    <!-- ACTION -->

    <record id="action_employee_directory" model="ir.actions.act_window">

        <field name="name">Employees</field>

        <field name="res_model">hr.employee</field>

        <field name="view_mode">list,form</field>

        <field name="search_view_id" ref="view_employee_search_assetflow"/>

    </record>

    <!-- MENU -->

    <menuitem
        id="menu_employee_directory"
        name="Employees"
        parent="menu_assetflow_root"
        action="action_employee_directory"
        sequence="20"/>

</odoo>