<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_audit_tree" model="ir.ui.view">
        <field name="name">wb.audit.tree</field>
        <field name="model">wb.audit</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="asset_id"/>
                <field name="auditor"/>
                <field name="audit_date"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_audit_form" model="ir.ui.view">
        <field name="name">wb.audit.form</field>
        <field name="model">wb.audit</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <group>
                        <field name="name"/>
                        <field name="asset_id"/>
                        <field name="auditor"/>
                    </group>

                    <group>
                        <field name="audit_date"/>
                        <field name="status"/>
                    </group>

                    <group>
                        <field name="remarks"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

        <record id="action_audit" model="ir.actions.act_window">
        <field name="name">Audit</field>
        <field name="res_model">wb.audit</field>
        <field name="view_mode">list,form</field>
    </record>

        <menuitem
        id="menu_audit"
        name="Audit"
        parent="menu_asset_root"
        action="action_audit"
        sequence="7"/>

</odoo>