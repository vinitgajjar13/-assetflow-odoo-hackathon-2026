<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_booking_tree" model="ir.ui.view">
        <field name="name">wb.booking.tree</field>
        <field name="model">wb.booking</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="asset_id"/>
                <field name="employee_id"/>
                <field name="start_datetime"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_booking_form" model="ir.ui.view">
        <field name="name">wb.booking.form</field>
        <field name="model">wb.booking</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <group>
                        <field name="name"/>
                        <field name="asset_id"/>
                        <field name="employee_id"/>
                    </group>

                    <group>
                        <field name="start_datetime"/>
                        <field name="end_datetime"/>
                        <field name="state"/>
                    </group>

                    <group>
                        <field name="purpose"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>


    <record id="action_booking" model="ir.actions.act_window">
        <field name="name">Bookings</field>
        <field name="res_model">wb.booking</field>
        <field name="view_mode">list,form</field>
    </record>

        <menuitem
        id="menu_booking"
        name="Bookings"
        parent="menu_asset_root"
        action="action_booking"
        sequence="5"/>

</odoo>